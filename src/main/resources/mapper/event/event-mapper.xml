<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="event"> 
  <!-- 김현주 : 행사 관련 SQL 쿼리 포함 -->
  
	<select id="selectEventById" resultType="com.kh.festait.event.model.vo.EventVO" parameterType="int">
	  SELECT * FROM event
	  WHERE event_id = #{eventId}
	</select>
	
	<select id="selectAllEvents" resultType="com.kh.festait.event.model.vo.EventVO">
	  SELECT * FROM event
	</select>
  
</mapper>
