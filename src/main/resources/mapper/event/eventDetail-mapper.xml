<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="eventMapper">

    <resultMap id="eventResultMap" type="com.kh.festait.eventdetail.model.vo.EventDetailVo">
        <id property="appId" column="APP_ID"/>
        <result property="userNo" column="USER_NO"/>
        <result property="eventCode" column="EVENT_CODE"/>
        <result property="statCode" column="STAT_CODE"/>
        <result property="appTitle" column="APP_TITLE"/>
        <result property="appSubTitle" column="APP_SUB_TITLE"/> <result property="appDetail" column="APP_DETAIL"/>
        <result property="location" column="LOCATION"/>
        <result property="locationDetail" column="LOCATION_DETAIL"/> <result property="postCode" column="POST_CODE"/> <result property="website" column="WEBSITE"/>
        <result property="startDate" column="START_DATE"/>
        <result property="endDate" column="END_DATE"/>
        <result property="startTime" column="START_TIME"/>
        <result property="endTime" column="END_TIME"/>
        <result property="createDate" column="CREATE_DATE"/>
        <result property="updateDate" column="UPDATE_DATE"/> <result property="submittedDate" column="SUBMITTED_DATE"/>
        <result property="approvedDate" column="APPROVED_DATE"/>
        <result property="appFee" column="APP_FEE"/>
        <result property="appItem" column="APP_ITEM"/>
        <result property="appHost" column="APP_HOST"/>
        <result property="appOrg" column="APP_ORG"/>
        <result property="appSponser" column="APP_SPONSER"/>
        <result property="managerName" column="MANAGER_NAME"/>
        <result property="email" column="EMAIL"/>
        <result property="tel" column="TEL"/>
        <result property="fax" column="FAX"/>
        <result property="adminComment" column="ADMIN_COMMENT"/>
    </resultMap>

    <select id="selectEventDetail" parameterType="int" resultMap="eventResultMap">
        SELECT
            EA.APP_ID,
            EA.USER_NO,
            EA.EVENT_CODE,
            EA.STAT_CODE,
            EA.APP_TITLE,
            EA.APP_SUB_TITLE, EA.APP_DETAIL,
            EA.LOCATION,
            EA.LOCATION_DETAIL, EA.POST_CODE, EA.WEBSITE,
            EA.START_DATE,
            EA.END_DATE,
            EA.START_TIME,
            EA.END_TIME,
            EA.CREATE_DATE,
            EA.UPDATE_DATE, EA.SUBMITTED_DATE,
            EA.APPROVED_DATE,
            EA.APP_FEE,
            EA.APP_ITEM,
            EA.APP_HOST,
            EA.APP_ORG,
            EA.APP_SPONSER,
            AM.MANAGER_NAME,
            AM.EMAIL,
            AM.TEL,
            AM.FAX,
            AM.ADMIN_COMMENT
        FROM EVENT_APPLICATION EA
        JOIN APP_MANAGER AM ON EA.APP_ID = AM.APP_ID
        WHERE EA.APP_ID = #{appId}
    </select>

</mapper>
